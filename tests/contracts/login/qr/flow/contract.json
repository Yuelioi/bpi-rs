{
  "schema_version": 2,
  "name": "login.qr.flow",
  "module": "login",
  "batch": "qr",
  "endpoint": "flow",
  "risk": "login-session",
  "status": "promoted",
  "profiles": [
    "anonymous"
  ],
  "sanitize": {
    "preset": [
      "account"
    ],
    "replace": {},
    "drop": [],
    "keep": []
  },
  "provenance": {
    "source": "local_probe_output",
    "tool": "bpi-probe",
    "tool_version": "0.2.0",
    "privacy": "no account data in waiting QR flow fixture"
  },
  "steps": [
    {
      "name": "generate",
      "contract": {
        "name": "login.qr_generate.anonymous",
        "request": {
          "method": "GET",
          "url": "https://passport.bilibili.com/x/passport-login/web/qrcode/generate",
          "query": {},
          "required_headers": [
            "user-agent",
            "referer",
            "origin"
          ],
          "headers": {},
          "auth": {
            "requires": []
          }
        },
        "expect": {
          "api_code": 0
        }
      },
      "extract": {
        "qrcode_key": "/response/body/data/qrcode_key"
      }
    },
    {
      "name": "poll",
      "contract": {
        "name": "login.qr_poll.anonymous",
        "request": {
          "method": "GET",
          "url": "https://passport.bilibili.com/x/passport-login/web/qrcode/poll",
          "query": {
            "qrcode_key": "${qrcode_key}"
          },
          "required_headers": [
            "user-agent",
            "referer",
            "origin"
          ],
          "headers": {},
          "auth": {
            "requires": []
          }
        },
        "expect": {
          "api_code": 0
        }
      }
    }
  ]
}
