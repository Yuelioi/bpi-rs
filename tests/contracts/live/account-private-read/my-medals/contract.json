{
  "schema_version": 2,
  "name": "live.my_medals",
  "module": "live",
  "batch": "account-private-read",
  "endpoint": "my-medals",
  "risk": "private-read",
  "status": "promoted",
  "profiles": [
    "anonymous",
    "normal",
    "vip"
  ],
  "request": {
    "method": "GET",
    "url": "https://api.live.bilibili.com/xlive/app-ucenter/v1/user/GetMyMedals",
    "query": {
      "page": "1",
      "page_size": "10"
    },
    "required_headers": [
      "user-agent",
      "referer",
      "origin"
    ],
    "headers": {},
    "auth": {
      "requires": []
    }
  },
  "sanitize": {
    "preset": [
      "account",
      "private_profile"
    ],
    "replace": {
      "$.data.items[].medal_info.target_id": 1000001,
      "$.data.items[].anchor_info.nick_name": "sanitized-user",
      "$.data.items[].anchor_info.face": "https://example.invalid/avatar.png"
    },
    "drop": [],
    "keep": [
      "$.data.page_info",
      "$.data.items[].medal_info.medal_name"
    ]
  },
  "provenance": {
    "source": "local_probe_output",
    "tool": "bpi-probe",
    "tool_version": "0.2.0",
    "privacy": "authenticated non-empty fixture redacts medal owner and room identity"
  },
  "cases": [
    {
      "name": "anonymous",
      "profile": "anonymous",
      "auth": {
        "requires": []
      },
      "response": {
        "api_code": -101,
        "fixture": "responses/anonymous.requires_login.json",
        "fixture_kind": "probe_error_body",
        "error": "requires_login"
      }
    },
    {
      "name": "normal",
      "profile": "normal",
      "auth": {
        "profile": "normal",
        "requires": [
          "cookie"
        ]
      },
      "response": {
        "api_code": 0,
        "fixture": "responses/normal.empty.success.json",
        "fixture_kind": "probe_body",
        "rust_model": "MyMedalsData"
      }
    },
    {
      "name": "vip",
      "profile": "vip",
      "auth": {
        "profile": "vip",
        "requires": [
          "cookie"
        ]
      },
      "response": {
        "api_code": 0,
        "fixture": "responses/vip.sample.success.json",
        "fixture_kind": "sanitized_probe_body",
        "rust_model": "MyMedalsData"
      }
    }
  ]
}
